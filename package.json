{
  "name": "realtime-bilingual-subtitles",
  "version": "0.1.0",
  "description": "Realtime bilingual subtitle overlay for macOS — local STT with SenseVoice + Google Translate",
  "license": "MIT",
  "author": "davedai",
  "repository": {
    "type": "git",
    "url": "https://github.com/davedai/realtime-bilingual-subtitles"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "node scripts/dev-electron.mjs",
    "build": "npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "type-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "test": "tsx --test tests/**/*.test.ts",
    "start": "electron ."
  },
  "dependencies": {
    "electron-store": "^10.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^37.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
